# Base URL of the AppSail backend (where /merchant, /portal, /auth live).
# In production this is your Catalyst AppSail URL; in dev the CRA proxy handles it (leave blank).
REACT_APP_API_BASE_URL=
# Salla App ID (for the embedded SDK; optional — the SDK reads it from the iframe).
REACT_APP_SALLA_APP_ID=1047822871
