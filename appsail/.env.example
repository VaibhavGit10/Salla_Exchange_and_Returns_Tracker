# Salla Returns & Exchanges v2 — backend env
# Non-secret operational config lives in ../app-config.json (committed).
# The SECRETS below are NEVER committed — set them in Catalyst Console > Environment Variables.
# Generate keys:
#   ENCRYPTION_KEY_B64 : node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#   SECURITY_PEPPER    : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   SESSION_SECRET     : node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
#   CRON_SECRET        : node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"

# ---- REQUIRED SECRETS (rotate the ones leaked in v1/app-config.json) ----
SALLA_CLIENT_SECRET=
SALLA_WEBHOOK_SECRET=
SECURITY_PEPPER=
ENCRYPTION_KEY_B64=
CRON_SECRET=
# Optional: signing key for merchant/portal session JWTs. Falls back to ENCRYPTION_KEY_B64 if unset.
SESSION_SECRET=

# ---- Operational (mirror of app-config.json; only needed for local `npm run dev`) ----
NODE_ENV=development
TZ=Asia/Riyadh
APP_BASE_URL=http://localhost:9000
DASHBOARD_URL=http://localhost:3000
SALLA_OAUTH_MODE=easy
SALLA_APP_ID=1047822871
SALLA_CLIENT_ID=
SALLA_OAUTH_TOKEN_URL=https://accounts.salla.sa/oauth2/token
SALLA_OAUTH_AUTHORIZE_URL=https://accounts.salla.sa/oauth2/auth
SALLA_API_BASE_URL=https://api.salla.dev
SALLA_INTROSPECT_URL=https://api.salla.dev/exchange-authority/v1/introspect
SALLA_INSTALL_URL_BASE=https://s.salla.sa/apps/install
SALLA_TOKEN_REFRESH_SKEW_SECONDS=120

# ---- Phase-0 capability matrix (auto-execute gates; keep FALSE until verified) ----
# Each capability stays off until its Salla scope is granted in the Partners portal AND the endpoint
# is verified live. When off, the service skips the Salla call and uses the assisted-manual fallback.
#   SALLA_REFUND_AUTO       requires scope: transactions.read_write
#   SALLA_STORE_CREDIT_AUTO requires scope: marketing.read_write
#   SALLA_RETURN_AWB_AUTO   requires scope: shippings.read_write
SALLA_REFUND_AUTO=false
SALLA_STORE_CREDIT_AUTO=false
SALLA_RETURN_AWB_AUTO=false
SESSION_TTL_SECONDS=7200
PORTAL_SESSION_TTL_SECONDS=14400
PORTAL_SESSION_TOUCH_INTERVAL_SECONDS=300
OTP_TTL_SECONDS=600
OTP_MAX_ATTEMPTS=3
OTP_LOCKOUT_SECONDS=900
OTP_RATE_LIMIT_WINDOW_SECONDS=300
OTP_RATE_LIMIT_MAX_IN_WINDOW=5
OTP_FROM_EMAIL=
FILESTORE_FOLDER_ID=17682000000848740
TENANT_CACHE_SEGMENT_ID=17682000000848733
DATA_RETENTION_DAYS=365
ATTACHMENT_RETENTION_DAYS=90
# Optional CORS allow-list (comma-separated). Empty = allow any origin (ZGS still gates in prod).
ALLOWED_ORIGINS=

# ---- LOCAL PREVIEW ONLY — never set these in production ----
# When DEV_DIRECT_LOGIN=true, POST /auth/dev-login mints a merchant session for DEV_DIRECT_STORE_ID,
# letting you open the embedded console locally (via `catalyst serve`) without the Salla iframe.
# In production these are unset, so /auth/dev-login returns 404.
DEV_DIRECT_LOGIN=
DEV_DIRECT_STORE_ID=
